{
  "name": "listings-ai-ui",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "dev:turbo": "next dev --turbopack",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "format": "prettier --write \"app/**/*.{ts,tsx,js,jsx,json,css,md}\" \"components/**/*.{ts,tsx,js,jsx,json,css,md}\"",
    "format:check": "prettier --check \"app/**/*.{ts,tsx,js,jsx,json,css,md}\" \"components/**/*.{ts,tsx,js,jsx,json,css,md}\"",
    "typecheck": "tsc --noEmit",
    "test": "vitest",
    "test:e2e": "playwright test",
    "openapi:generate": "openapi-ts",
    "openapi:generate:local": "OPENAPI_INPUT=http://127.0.0.1:8000/openapi.json npm run openapi:generate",
    "openapi:spec": "cd ../api && uv run python scripts/export_openapi_to_ui.py",
    "openapi:refresh": "npm run openapi:spec && npm run openapi:generate"
  },
  "dependencies": {
    "@hey-api/client-fetch": "^0.13.1",
    "@llamaindex/chat-ui": "0.5.17",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-tabs": "^1.1.13",
    "@tanstack/react-query": "^5.99.2",
    "@tanstack/react-query-devtools": "^5.99.2",
    "ai": "4.3.16",
    "class-variance-authority": "^0.7.1",
    "clsx": "2.1.1",
    "lucide-react": "^0.544.0",
    "mapbox-gl": "^3.22.0",
    "next": "15.5.15",
    "next-themes": "^0.4.6",
    "posthog-js": "^1.372.3",
    "posthog-node": "^5.30.6",
    "radix-ui": "^1.4.3",
    "react": "19.2.5",
    "react-dom": "19.2.5",
    "react-map-gl": "^8.1.1",
    "recharts": "^3.8.1",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3",
    "@hey-api/openapi-ts": "0.96.1",
    "@playwright/test": "^1.48.0",
    "@tailwindcss/postcss": "^4",
    "@testing-library/jest-dom": "^6.6.0",
    "@testing-library/react": "^16.1.0",
    "@testing-library/user-event": "^14.5.0",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitejs/plugin-react": "^4.3.0",
    "eslint": "^9",
    "eslint-config-next": "15.5.3",
    "jsdom": "^25.0.0",
    "prettier": "^3.3.3",
    "tailwindcss": "^4",
    "tw-animate-css": "^1.4.0",
    "typescript": "^5",
    "vitest": "^2.1.0"
  }
}
